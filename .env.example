# Copy to .env and edit if you want. NEVER commit .env.
#
# x-agent has ZERO publishing credentials: it drafts a post locally with
# Ollama and hands you the result to copy yourself. No tokens, no OAuth.

# --- Local Ollama LLM ---
OLLAMA_BASE_URL=http://localhost:11434
# Pick a model you have pulled (`ollama list` to see them). Common options:
#   llama3:latest       (default - 8B, balanced quality + speed)
#   llama3.1:8b         (newer, slightly better instruction-following)
#   llama3.2:3b         (smaller + faster, great for laptops)
#   qwen2.5:7b          (strong general-purpose alternative)
OLLAMA_MODEL=llama3:latest

# --- Formatter ---
# Per-tweet character ceiling. X allows 280 but we leave headroom for
# thread numbering. Legacy name X_MAX_TWEET_CHARS still works.
MAX_TWEET_CHARS=275

# --- Persona clone (optional) ---
# Where persona spec/transcript/embeddings/personality.md live.
# Default ~/.x-agent/personas
# PERSONA_DIR=~/.x-agent/personas
# Local Ollama embedding model (run `ollama pull nomic-embed-text` first)
# EMBEDDING_MODEL=nomic-embed-text
# Override the model the persona-consistency critic uses (defaults to OLLAMA_MODEL)
# CRITIC_MODEL=
# CRITIC_MIN_SCORE=4
# CRITIC_MAX_ATTEMPTS=2
# PERSONA_TOP_K=4

# --- Web research (optional) ---
# Enabling research is opt-in per-request from the UI/CLI. These knobs only
# affect what happens once a request opts in. Without keys, DuckDuckGo is
# used (no signup required).
# 'auto' = Tavily if key present, else Brave if present, else DuckDuckGo.
# RESEARCH_PROVIDER=auto
# TAVILY_API_KEY=
# BRAVE_SEARCH_API_KEY=
# RESEARCH_MAX_RESULTS=4
# RESEARCH_FETCH_TIMEOUT_S=10
# RESEARCH_MAX_CONTENT_CHARS=8000

# --- Voice pipeline (optional) ---
# End-to-end voice persona creation: Kokoro-82M (ONNX) reads questions aloud
# via /api/voice/speak and faster-whisper transcribes spoken answers via
# /api/voice/transcribe. All-local; no cloud calls. Models are downloaded
# to VOICE_MODEL_DIR on first use (~350 MB total).
# VOICE_ENABLED=true
# faster-whisper tag. English-only ('.en') is ~30% smaller. Common picks:
#   tiny.en (~75 MB, fast, less accurate)
#   base.en (~140 MB, balanced)
#   small.en (~470 MB, recommended default)
# VOICE_STT_MODEL=small.en
# CTranslate2 compute precision (int8 = CPU friendly; float16 = GPU)
# VOICE_STT_COMPUTE_TYPE=int8
# Kokoro voice id (see hexgrad/Kokoro-82M VOICES.md). Examples:
#   am_michael -- American male, clean (default)
#   am_adam   -- American male, deeper
#   bm_george -- British male
#   af_bella  -- American female, warm
#   af_sarah  -- American female, neutral
# VOICE_TTS_VOICE=am_michael
# VOICE_TTS_SPEED=1.0
# VOICE_TTS_LANG=en-us
# Where ONNX weights are cached (must be writable; /data/models in Docker)
# VOICE_MODEL_DIR=~/.x-agent/models
# Upload safety caps
# VOICE_MAX_AUDIO_BYTES=8000000
# VOICE_MAX_AUDIO_SECONDS=120
# VOICE_TTS_MAX_CHARS=800
# VOICE_RATE_LIMIT_PER_5MIN=20

# Host-side voice sidecar. When set, the FastAPI container proxies
# /api/voice/* to this URL instead of loading Kokoro / faster-whisper
# inside the container. The sidecar (scripts/voice_server.py, started
# by scripts/start_voice.sh) lives on the HOST, just like Ollama on
# :11434. This is the recommended setup behind corporate TLS
# interception (Zscaler, Cisco Secure Access, etc) where the container
# CA bundle differs from the host keychain. Docker compose sets this
# automatically to http://host.docker.internal:8765. Leave empty for
# fully-in-container engines.
# VOICE_REMOTE_URL=
#
# Model files are staged onto the host by scripts/start_voice.sh, which
# delegates to scripts/download_models.sh. That script uses host `curl`
# (OS trust store) so it works behind corporate TLS interception. Run
# it manually for an air-gapped / pre-warmed setup:
#   ./scripts/download_models.sh
#   VOICE_STT_MODEL=tiny.en ./scripts/download_models.sh   # smaller default
# Files land under VOICE_MODEL_DIR (~/.x-agent/models by default).
